{
  "compilerOptions": {
    "target": "ES2020",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "dist-server",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true
  },
  "include": ["server/**/*.ts", "src/data/demo.ts", "src/data/empty.ts", "src/types/entities.ts", "src/lib/utils.ts", "src/lib/leadStatus.ts"]
}
